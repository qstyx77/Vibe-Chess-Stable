
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    // Users can only read their own data, but anyone can write to create a user profile.
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isSignedIn();
    }
    
    // Leaderboard is a public document that can be read by anyone.
    // It is written to by a server-side process, so client-side writes are denied.
    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Game data is private to the players involved.
    match /games/{gameId} {
      allow read, write: if isSignedIn() && (resource.data.player1Id == request.auth.uid || resource.data.player2Id == request.auth.uid);
    }

    match /games/{gameId}/pieces/{pieceId} {
       allow read, write: if get(/databases/$(database)/documents/games/$(gameId)).data.player1Id == request.auth.uid || get(/databases/$(database)/documents/games/$(gameId)).data.player2Id == request.auth.uid;
    }
  }
}
